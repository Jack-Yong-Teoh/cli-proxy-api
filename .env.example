# CPA image override (optional)
CPA_IMAGE=eceasy/cli-proxy-api:latest

# CPA runtime bind mounts
CPA_CONFIG_PATH=./cpa/config.yaml
CPA_AUTH_PATH=./cpa/auths
CPA_LOG_PATH=./cpa/logs

# Drission scraper flow settings
HEADLESS=true
FLOW_MODE=open_temp_mail_only
SIGNUP_URL=
TEMP_MAIL_URL=https://mail.chatgpt.org.uk
TEMP_GENERATE_BTN_SELECTOR=
TEMP_EMAIL_SELECTOR=
TEMP_EMAIL_BODY_SELECTOR=
SIGNUP_EMAIL_SELECTOR=
SIGNUP_SEND_CODE_SELECTOR=
SIGNUP_CODE_SELECTOR=
SIGNUP_NAME_SELECTOR=
SIGNUP_BIRTHDAY_SELECTOR=
SIGNUP_SUBMIT_SELECTOR=
PROFILE_NAME=Test User
PROFILE_BIRTHDAY=1990-01-01
EMAIL_CODE_REGEX=(\d{6})
EMAIL_WAIT_TIMEOUT_SECONDS=120
EMAIL_POLL_SECONDS=5
MAX_SIGNUPS=1
BETWEEN_SIGNUP_DELAY_SECONDS=15
